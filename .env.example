# Binance Futures Testnet API credentials.
# Create them at https://testnet.binancefuture.com  ->  API Key section.
# Copy this file to ".env" and fill in your keys. Never commit the real .env.

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Optional override (defaults to the USDT-M Futures Testnet):
BINANCE_BASE_URL=https://testnet.binancefuture.com
# NOTE: Binance migrated the testnet in 2026 — for live signed calls use the
# current Demo Trading endpoint instead:
# BINANCE_BASE_URL=https://demo-fapi.binance.com
